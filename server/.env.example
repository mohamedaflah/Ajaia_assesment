NODE_ENV=development
PORT=4000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret_min_16_chars
CORS_ORIGIN=http://localhost:5173

# Optional: JSON array of { "email": "...", "password": "..." }
SEED_USERS=[{"email":"owner@example.com","password":"Password123!"},{"email":"alice@example.com","password":"Password123!"}]

