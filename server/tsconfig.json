{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "ignoreDeprecations": "5.0",

    "lib": ["ES2022"],

    "sourceMap": true,
    "strict": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/__tests__"]
}