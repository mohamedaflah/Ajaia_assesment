{
  "compilerOptions": {
    /* =========================
       FILE STRUCTURE
    ========================= */
    "rootDir": "./src",
    "outDir": "./dist",

    /* =========================
       ENVIRONMENT
    ========================= */
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node"],

    /* =========================
       OUTPUT
    ========================= */
    "sourceMap": true,
    "declaration": false,

    /* =========================
       TYPE SAFETY
    ========================= */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* =========================
       COMPATIBILITY (IMPORTANT)
    ========================= */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    /* =========================
       BUILD STABILITY (IMPORTANT)
    ========================= */
    "forceConsistentCasingInFileNames": true
  },
  "exclude": ["node_modules", "dist"]
}